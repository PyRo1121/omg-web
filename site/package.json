{
  "name": "omg-site",
  "version": "1.0.0",
  "description": "OMG Package Manager - Marketing Site",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "dev:docs": "cd ../omg-docs && bun run dev",
    "build": "bun run build:docs && bun run build:site",
    "build:site": "vinxi build",
    "build:docs": "cd ../omg-docs && bun run build && mkdir -p ../site/public/docs && cp -r dist/* ../site/public/docs/",
    "preview": "vinxi start",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "audit": "bunx better-npm-audit audit",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "check:fix": "bun run lint:fix && bun run format"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@sentry/solid": "^10.36.0",
    "@solid-primitives/keyboard": "^1.3.3",
    "@solid-primitives/scheduled": "^1.5.2",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@solidjs/start": "^1.2.1",
    "@tanstack/solid-query": "^5.90.23",
    "@tanstack/solid-table": "^8.21.3",
    "@types/three": "^0.182.0",
    "apexcharts": "^5.3.6",
    "better-auth": "^1.4.18",
    "clsx": "^2.1.1",
    "cmdk-solid": "^1.1.2",
    "drizzle-orm": "^0.45.1",
    "kysely": "^0.28.10",
    "kysely-d1": "^0.4.0",
    "lucide-solid": "^0.562.0",
    "motion": "^12.29.2",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.21.0",
    "solid-apexcharts": "^0.6.0",
    "solid-js": "^1.9.11",
    "solid-markdown": "^2.1.1",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "vinxi": "^0.5.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.0.0",
    "eslint-plugin-solid": "^0.14.0",
    "postcss": "^8.5.3",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.7.0",
    "vite": "^6.3.5"
  }
}
