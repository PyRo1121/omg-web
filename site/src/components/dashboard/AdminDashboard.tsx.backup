type DateRange = '7d' | '30d' | '90d' | 'custom';
type SavedView = {
  id: string;
  name: string;
  tab: AdminTab;
  dateRange: DateRange;
  segment: string;
  compareEnabled: boolean;
};

import {
  ExecutiveKPIDashboard,
  RealTimeCommandCenter,
  CRMProfileCard,
  CRMProfileCardTableRow,
} from './premium';
import type {
  ExecutiveKPI,
  AdvancedMetrics,
  FirehoseEvent,
  GeoDistribution,
